{
    "editor.minimap.enabled": false,
    "editor.semanticHighlighting.enabled": true,
    "editor.mouseWheelZoom": true,
    "editor.fontFamily": "'JetBrainsMono Nerd Font', 'RobotoMono Nerd Font', monospace",
    "editor.renderControlCharacters": true,
    "editor.smoothScrolling": true,
    "editor.fastScrollSensitivity": 10,
    "editor.suggestSelection": "first",
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.detectIndentation": false,
    "workbench.editor.enablePreview": false,
    "workbench.productIconTheme": "fluent-icons",
    "workbench.startupEditor": "newUntitledFile",
    "window.openFilesInNewWindow": "off",
    "window.openFoldersInNewWindow": "on",
    "diffEditor.ignoreTrimWhitespace": false,
    "terminal.integrated.fontFamily": "RobotoMono Nerd Font",
    "files.exclude": {
        "**/.classpath": true,
        "**/.project": true,
        "**/.settings": true,
        "**/.factorypath": true
    },
    "git.enableSmartCommit": true,
    "git.autofetch": true,
    "git.confirmSync": false,
    "[python]": {
        "editor.defaultFormatter": "ms-python.black-formatter"
    },
    "python.languageServer": "Jedi",
    "latex-workshop.view.pdf.viewer": "tab",
    "latex-workshop.latex.recipe.default": "lastUsed",
    "latex-workshop.view.pdf.color.dark.backgroundColor": "#000000",
    "latex-workshop.latex.autoBuild.run": "onSave",
    "latex-workshop.message.warning.show": false,
    "latex-workshop.message.error.show": false,
    "latex-workshop.synctex.afterBuild.enabled": true,
    // "latex-workshop.latex.outDir": "%DOC_EXT%/../../build/%DOCFILE%",
    "latex-workshop.latex.recipes": [
        {
            "name": "latexmk-xelatex",
            "tools": [
            "latexmk-xelatex"
            ]
        },
        {
            "name": "tectonic-compile",
            "tools": ["tectonic-compile"]
        },
        {
            "name": "pdflatex",
            "tools": [
                "pdflatex"
            ]
        },
        {
            "name": "pdflatex ➞ bibtex ➞ pdflatex × 2",
            "tools": [
                "pdflatex",
                "bibtex",
                "pdflatex",
                "pdflatex"
            ]
        },
        {
            "name": "pdflatex ➞ biber ➞ pdflatex × 2",
            "tools": [
                "pdflatex",
                "biber",
                "pdflatex",
                "pdflatex"
            ]
        },
        {
            "name": "pdf_with_embedded_fonts",
            "tools": [
                "gs",
            ]
        },
    ],
    "latex-workshop.latex.tools": [
        {
            "name": "latexmk-xelatex",
            "command": "latexmk",
            "args": [
            "-xelatex",
            "-synctex=1",
            "-interaction=nonstopmode",
            "-file-line-error",
            "%DOC%"
            ],
            "env": {}
        },
        {
            "name": "tectonic-compile",
            "command": "tectonic",
            "args": ["-X", "compile", "%DOCFILE_EXT%", "--only-cached", "--synctex", "--print","--keep-logs", "--keep-intermediates"],
            "env": {}
        },
        {
            "name": "pdflatex",
            "command": "pdflatex",
            "args": [
                "-synctex=1",
                "-interaction=nonstopmode",
                "-file-line-error",
                "%DOC%"
            ],
            "env": {}
        },
        {
            "name": "gs",
            "command": "gs",
            "args": [
                "-dNOPAUSE",
                "-dBATCH",
                "-sDEVICE=pdfwrite",
                "-dPDFSETTINGS=/prepress",
                "-dEmbedAllFonts=true",
                "-sOutputFile=%DOC%_with_embedded_fonts.pdf",
                "-f",
                "%DOC%.pdf"
            ],
            "env": {}
        },
        {
            "name": "bibtex",
            "command": "bibtex",
            "args": [
                "%DOCFILE%"
            ],
            "env": {}
        },
        {
            "name": "biber",
            "command": "biber",
            "args": [
                "%DOCFILE%"
            ]
        }
    ],
    "[latex]": {
        "editor.fontFamily": "'Roboto', sans-serif",
    },
    "explorer.confirmDragAndDrop": false,
    "latex-workshop.texcount.autorun": "onSave",
    "cSpell.enableFiletypes": [
        "latex"
    ],
    "projectManager.git.baseFolders": [
        "~/repository"
    ],
    "projectManager.git.maxDepthRecursion": 2,
    "redhat.telemetry.enabled": false,
    "go.toolsManagement.autoUpdate": true,
    "[json]": {
        "editor.defaultFormatter": "vscode.json-language-features"
    },
    "[yaml]": {
        "editor.defaultFormatter": "redhat.vscode-yaml"
    },
    "[css]": {
        "editor.defaultFormatter": "vscode.css-language-features"
    },
    "java.edit.smartSemicolonDetection.enabled": true,
    "indentRainbow.colors": [
        "rgba(29, 78, 137,0.15)",
        "rgba(58, 178, 202,0.15)",
        "rgba(125, 207, 182, 0.15)",
        "rgba(251, 209, 162,0.15)",
        "rgba(247, 146, 86,0.15)",
        "rgba(247, 146, 86,0.1)",
        "rgba(247, 146, 86,0.05)"
    ],
    "git.replaceTagsWhenPull": true,
    "markdown.preview.scrollEditorWithPreview": true,
    "workbench.iconTheme": "material-icon-theme",
    "markdown.preview.scrollPreviewWithEditor": true,
    "kanban-markdown.compactMode": true,
    "kanban-markdown.columns": [
        {
            "id": "backlog",
            "name": "Backlog",
            "color": "#6b7280"
        },
        {
            "id": "todo",
            "name": "To Do",
            "color": "#3b82f6"
        },
        {
            "id": "in-progress",
            "name": "In Progress",
            "color": "#f59e0b"
        },
        {
            "id": "review",
            "name": "Review",
            "color": "#8b5cf6"
        },
        {
            "id": "done",
            "name": "Done",
            "color": "#22c55e"
        },
        {
            "id": "wont-do",
            "name": "Won't Do",
            "color": "#FF0000"
        }
    ],
    "window.titleBarStyle": "native",
    "window.customTitleBarVisibility": "never",
    "custom-ui-style.electron": {
    // Frameless window (no title bar, no MacOS traffic light buttons)
    "frame": false,
    // Disable rounded corners (MacOS)
    //   "roundedCorners": false,
    },
    "[lua]": {
        "editor.defaultFormatter": "JohnnyMorganz.stylua"
    },
    "roo-cline.debug": false,
    "roo-cline.allowedCommands": [
        "git log",
        "git diff",
        "git show",
        "npm test",
        "npm install",
        "tsc"
    ],
    "roo-cline.deniedCommands": [],
    "git.openRepositoryInParentFolders": "never",
    "workbench.colorTheme": "Andromeda Bordered",
}